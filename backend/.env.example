APP_NAME=LeafletPilot API
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+asyncpg://leafletpilot:leafletpilot@localhost:5432/leafletpilot
TEST_DATABASE_URL=
LOCAL_STORAGE_DIR=storage
LOG_LEVEL=INFO

# Development placeholder only. Set a strong secret in deployed environments.
JWT_SECRET_KEY=change-this-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

PLATFORM_ADMIN_ENABLED=false
PLATFORM_JWT_SECRET=change-this-platform-secret-at-least-32-chars
PLATFORM_ACCESS_TOKEN_EXPIRE_MINUTES=240
PUBLIC_SIGNUP_THROTTLE_SECRET=change-this-signup-throttle-secret-at-least-32-chars
PUBLIC_SIGNUP_THROTTLE_WINDOW_MINUTES=60
PUBLIC_SIGNUP_THROTTLE_LIMIT=3
