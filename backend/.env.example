APP_NAME=LeafletPilot API
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+asyncpg://leafletpilot:leafletpilot@localhost:5432/leafletpilot
TEST_DATABASE_URL=
INVITATION_EMAIL_DELIVERY=disabled
INVITATION_SMTP_HOST=
INVITATION_SMTP_PORT=587
INVITATION_SMTP_USERNAME=
INVITATION_SMTP_PASSWORD=
INVITATION_SMTP_FROM_ADDRESS=
INVITATION_SMTP_FROM_NAME=LeafletPilot
INVITATION_SMTP_SECURITY=starttls
INVITATION_SMTP_TIMEOUT_SECONDS=15
LOCAL_STORAGE_DIR=storage
LOG_LEVEL=INFO

# Disabled by default. Enable only in an isolated demo environment and set all three allow-list values.
DEMO_OPERATIONS_ENABLED=false
DEMO_MARKET_ID=
DEMO_MARKET_SLUG=
DEMO_OWNER_EMAIL=
# Required only to create a missing synthetic owner; never log or commit this value.
DEMO_OWNER_INITIAL_PASSWORD=

# Development placeholder only. Set a strong secret in deployed environments.
JWT_SECRET_KEY=change-this-development-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

PLATFORM_ADMIN_ENABLED=false
PLATFORM_JWT_SECRET=change-this-platform-secret-at-least-32-chars
PLATFORM_ACCESS_TOKEN_EXPIRE_MINUTES=240
PUBLIC_SIGNUP_THROTTLE_SECRET=change-this-signup-throttle-secret-at-least-32-chars
PUBLIC_SIGNUP_THROTTLE_WINDOW_MINUTES=60
PUBLIC_SIGNUP_THROTTLE_LIMIT=3
TRUSTED_PROXY_IPS=
