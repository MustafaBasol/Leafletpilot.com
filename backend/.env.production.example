# Copy to backend/.env only on a production host if running outside Compose.
# Do not commit real credentials.

ENVIRONMENT=production
DEBUG=false
DATABASE_URL=
INVITATION_EMAIL_DELIVERY=disabled
INVITATION_SMTP_HOST=
INVITATION_SMTP_PORT=587
INVITATION_SMTP_USERNAME=
INVITATION_SMTP_PASSWORD=
INVITATION_SMTP_FROM_ADDRESS=
INVITATION_SMTP_FROM_NAME=LeafletPilot
INVITATION_SMTP_SECURITY=starttls
INVITATION_SMTP_TIMEOUT_SECONDS=15

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

PLATFORM_ADMIN_ENABLED=false
PLATFORM_JWT_SECRET=
PLATFORM_ACCESS_TOKEN_EXPIRE_MINUTES=240
PUBLIC_SIGNUP_THROTTLE_SECRET=
PUBLIC_SIGNUP_THROTTLE_WINDOW_MINUTES=60
PUBLIC_SIGNUP_THROTTLE_LIMIT=3

# Pydantic JSON list formatting is required.
BACKEND_CORS_ORIGINS=["https://app.example.com"]
FRONTEND_BASE_URL=https://app.example.com
TRUSTED_HOSTS=["api.example.com","127.0.0.1","localhost","backend"]
TRUSTED_PROXY_IPS=
LOCAL_STORAGE_DIR=/app/storage
LOG_LEVEL=INFO

# Keep disabled in production unless an explicitly isolated demo database is being operated.
DEMO_OPERATIONS_ENABLED=false
DEMO_MARKET_ID=
DEMO_MARKET_SLUG=
DEMO_OWNER_EMAIL=

TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_HTTP_TIMEOUT_SECONDS=20
TELEGRAM_HTTP_MAX_ATTEMPTS=1
