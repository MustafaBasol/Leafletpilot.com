# Copy this file to a private production env file. Do not commit real values.

ENVIRONMENT=production
DEBUG=false

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Internal Compose database URL is assembled in docker-compose.production.yml.
# Use this only for one-off commands outside Compose.
DATABASE_URL=

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

PLATFORM_ADMIN_ENABLED=false
PLATFORM_JWT_SECRET=
PLATFORM_ACCESS_TOKEN_EXPIRE_MINUTES=240
PUBLIC_SIGNUP_THROTTLE_SECRET=
PUBLIC_SIGNUP_THROTTLE_WINDOW_MINUTES=60
PUBLIC_SIGNUP_THROTTLE_LIMIT=3

# Pydantic JSON list formatting is required.
BACKEND_CORS_ORIGINS=["https://app.example.com"]
FRONTEND_BASE_URL=https://app.example.com
TRUSTED_HOSTS=["api.example.com","127.0.0.1","localhost","backend"]
TRUSTED_PROXY_IPS=
LOCAL_STORAGE_DIR=/app/storage
LOG_LEVEL=INFO

TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_HTTP_TIMEOUT_SECONDS=20
TELEGRAM_HTTP_MAX_ATTEMPTS=1

APP_DOMAIN=
API_DOMAIN=

# Public frontend value embedded at image build time. It is not a secret.
VITE_API_BASE_URL=https://api.example.com/api

# Optional when using deploy/traefik/docker-compose.traefik.example.yml.
TRAEFIK_NETWORK=
CERT_RESOLVER=
